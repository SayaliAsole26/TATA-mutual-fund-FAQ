# Groq LLM
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

# BGE embeddings (local, free via sentence-transformers)
EMBEDDING_MODEL_LARGE=BAAI/bge-large-en-v1.5
EMBEDDING_MODEL_SMALL=BAAI/bge-small-en-v1.5

# Scheduler timezone (daily ingestion at 10:00 IST)
TIMEZONE=Asia/Kolkata

# Optional overrides (defaults resolve relative to project root)
# DATA_DIR=data
# CORPUS_REGISTRY_PATH=data/corpus_registry.json
# Paths: data/raw (snapshots), data/processed (parsed JSON), data/index (embeddings)
# FETCH_DELAY_SECONDS=1.5
# FETCH_TIMEOUT_SECONDS=30
# PREFER_LOCAL_SNAPSHOTS=true
