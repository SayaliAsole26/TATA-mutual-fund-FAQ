# Groq LLM
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.1

# BGE embeddings (local, free via sentence-transformers)
EMBEDDING_MODEL_LARGE=BAAI/bge-large-en-v1.5
EMBEDDING_MODEL_SMALL=BAAI/bge-small-en-v1.5

# Retrieval (cosine distance threshold — lower is better)
RETRIEVAL_MAX_DISTANCE=0.55

# Scheduler timezone (daily ingestion at 10:00 IST)
TIMEZONE=Asia/Kolkata

# API (Phase 2c) — comma-separated frontend dev origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Also allow Vercel preview/production URLs (set to empty to disable)
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Admin manual ingest (Phase 3) — POST /api/ingest with header X-Admin-Key
INGEST_API_KEY=your_ingest_admin_key

# Phase 5 — rate limit & monitoring
CHAT_RATE_LIMIT_PER_MINUTE=30
CORPUS_STALE_HOURS=26
AUTO_INGEST_ON_STARTUP=false

# Optional overrides (defaults: ../data at repo root)
# DATA_DIR=../data
# CORPUS_REGISTRY_PATH=../data/corpus_registry.json
# FETCH_DELAY_SECONDS=1.5
# FETCH_TIMEOUT_SECONDS=30
# PREFER_LOCAL_SNAPSHOTS=true
